{
  "expo": {
    "name": "MUULOX",
    "slug": "muuloxapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AppIcons/appstore.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3FBFC"
    },
    "ios": {
      "bundleIdentifier": "com.muuloxsrl.muuloxapp",
      "icon": "./assets/AppIcons/appstore.png",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Aplicația are nevoie de acces la cameră pentru funcțiile portalului (ex. scanare, încărcare documente).",
        "NSPhotoLibraryUsageDescription": "Aplicația are nevoie de acces la galerie pentru a selecta și încărca fișiere în portal.",
        "NSPhotoLibraryAddUsageDescription": "Aplicația are nevoie de permisiune pentru a salva imagini din portal în galerie.",
        "NSMicrophoneUsageDescription": "Aplicația are nevoie de acces la microfon pentru funcțiile portalului care folosesc înregistrare video."
      }
    },
    "android": {
      "icon": "./assets/AppIcons/playstore.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F3FBFC"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.muulox_srl.muuloxapp",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3639a632-4d93-4b55-82fc-e30b9d6e58f5"
      }
    },
    "plugins": [
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3FBFC",
          "image": "./assets/splash.png",
          "imageWidth": 280
        }
      ]
    ]
  }
}
